      "92364603-c0fc-4397-b5ec-c99b472e37cf" : {
        "jipipe:graph-compartment" : "640506e5-bac4-4bf2-83ca-47e40c998498",
        "jipipe:alias-id" : "annotate-disk-1",
        "jipipe:slot-configuration" : {
          "input" : {
            "Input" : {
              "slot-data-type" : "imagej-imgplus",
              "slot-type" : "Input",
              "name" : "Input",
              "custom-name" : null,
              "description" : "",
