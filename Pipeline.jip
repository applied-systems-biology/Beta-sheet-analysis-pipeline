        "description" : "Optional annotation type where the image title is written."
      },
      "c1439606-8752-4593-b547-51bee22c4fe8/jipipe:adaptive-parameters/attach-only-non-default-parameter-annotations" : {
        "name" : "Attach only non-default parameter annotations",
        "description" : "If multiple parameters are allowed, attach only parameter annotations that have different values from the current settings. Requires 'Attach parameter annotations' to be enabled."
      },
      "92364603-c0fc-4397-b5ec-c99b472e37cf/jipipe:node:ui-locked" : {
        "pinned" : true,
        "hidden" : true,
        "name" : "Lock location/size",
        "description" : "If enabled, lock the location and size of this node. Does not affect automated alignment operations. Will lock the size if the node supports a resize handle. Will prevent deletion of the node by the user. Slots can still be edited/connected and parameters can still be changed."
      },
      "ac27f9d7-f34a-4c07-a34c-8ae3bad983fc/output-from-imagej-importers/Output" : {
        "name" : "Output"
      },
      "c1439606-8752-4593-b547-51bee22c4fe8/swap-dimensions" : {
        "name" : "Swap dimensions",
        "description" : "Allows reassignment of dimensional axes (e.g., channel, Z and time).  Bio-Formats is supposed to be smart about handling multidimensional image data, but in some cases gets things wrong. For example, when stitching together a dataset from multiple files using the Group files with similar names option, Bio-Formats may not know which dimensional axis the file numbering is supposed to represent. It will take a guess, but in case it guesses wrong, you can use Swap dimensions to reassign which dimensions are which."
      },
      "07acd165-9687-4929-b31b-680baf0f7f9c/jipipe:data-batch-generation/annotation-merge-strategy" : {
        "name" : "Merge same annotation values",
        "description" : "Determines which strategy is applied if different values for the same annotation columns are encountered."
      },
      "d29b4a11-2540-47a1-9fbd-215318644b13/external-code" : {
        "important" : true,
        "name" : "External code",
        "description" : "If enabled, run code from an input slot"
      },
      "23f70bb2-7617-4045-b74f-56f28be83165/jipipe:parameter-slot-algorithm/attach-only-non-default-parameter-annotations" : {
