              "is-virtual" : true,
              "save-outputs" : true,
              "is-optional" : false
            },
            "Output 1" : {
              "slot-data-type" : "imagej-roi",
              "slot-type" : "Output",
              "name" : "Output 1",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:metadata-v1" : {
          "location/640506e5-bac4-4bf2-83ca-47e40c998498/x" : 4,
          "location/640506e5-bac4-4bf2-83ca-47e40c998498/y" : 14,
          "location/_/y" : 48,
          "location/_/x" : 13
        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "// --- Load existing ROI for this image if present,\n// --- otherwise load a template ROI, let user adapt, then save as new.\n\n// Select the input image window\nselectWindow(\"Input\");\n\n// Get image title and make a base name (without extension)\nimgTitle = getJIPipeAnnotation(\"#FILE\");\n\ndot = lastIndexOf(imgTitle, \".\");\n\nbaseName = imgTitle; \n\n\n// ROI folder (where per-image ROIs live)\nroiDir = getJIPipeAnnotation(\"Parent\");\n\n// Expected ROI path for this image\nroiPath = roiDir + \"/\" + baseName + \".zip\";\n\n// Clear ROI Manager\nroiManager(\"Reset\");\n\n// If ROI already exists for this image: load and continue SILENTLY (no dialogs)\nif (File.exists(roiPath)) {\n    roiManager(\"Open\", roiPath);\n    roiManager(\"Show All with labels\");\n}\n// Otherwise: import template ROI, let user adapt, then save new ROI\nelse {\n    templatePath = File.openDialog(\"Choose a ready-to-use/template ROI (.zip or .roi)\");\n    if (templatePath==\"\") exit(\"No template ROI chosen.\");\n\n    roiManager(\"Open\", templatePath);\n\n    if (roiManager(\"count\") == 0)\n        exit(\"Template ROI file contained no ROI.\");\n\n    roiManager(\"Show All with labels\");\n    roiManager(\"Select\", 0);\n\n    waitForUser(\n        \"Template ROI loaded.\\n\\n\" +\n        \"Please ADAPT the ROI to fit this input image:\\n\" +\n        \"- move/resize/edit it as needed\\n\\n\" +\n        \"When you are done, click OK to save the new ROI.\"\n    );\n\n    // Save adapted ROI(s) under the image-specific name\n    roiManager(\"Save\", roiPath);\n}\n\n// Rename output if you still want that final step\nrename(\"Output\");\n",
          "collapsed" : false
        },
        "import-delay" : 1000,
        "jipipe:node:bookmarked" : false,
        "jipipe:algorithm:pass-through" : false,
        "jipipe:node:name" : "Annotate Disk",
        "jipipe:algorithm:runtime-partition" : {
          "index" : 0
        },
        "jipipe:node:description" : "<html><head></head><body></body></html>",
        "external-code" : false,
        "jipipe:local-parallelization-num-threads" : {
          "content" : 1,
          "enabled" : false
        },
