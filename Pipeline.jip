      "ffaad8d9-b0da-4366-adc2-226220d7962e/subfolder" : {
        "name" : "Subfolder",
        "description" : "Optional. If non-empty, all files are extracted from the provided sub-folder. The sub-folder navigation is applied before recursive search (if 'Recursive' is enabled)."
      },
      "23f70bb2-7617-4045-b74f-56f28be83165/jipipe:adaptive-parameters/overridden-parameters" : {
        "important" : true,
        "name" : "Overridden parameters",
        "description" : "Here you can override the value of parameters based on annotations. The 'Value' settings should return a value for the parameter type or a JSON string that can be converted into a valid parameter value. The 'Parameter key' setting determines to which parameter this value is written to."
      },
      "c1439606-8752-4593-b547-51bee22c4fe8/title-annotation" : {
