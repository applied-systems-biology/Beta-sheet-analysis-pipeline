      "ac27f9d7-f34a-4c07-a34c-8ae3bad983fc" : {
        "jipipe:graph-compartment" : "6de3573d-bca3-4fc2-a6bf-c1737a358a0c",
        "jipipe:alias-id" : "basic-i-1",
        "jipipe:slot-configuration" : {
          "input" : {
