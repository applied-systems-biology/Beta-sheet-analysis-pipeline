  "jipipe:project-jipipe-version" : "6.0.0",
  "metadata" : {
    "name" : "ß-sheet analysis pipeline",
    "description" : "<html><head></head><body></body></html>",
    "summary" : "<html>\n  <head>\n    \n  </head>\n  <body>\n    <p class=\"MsoNormal\">\n      <span><font face=\"Calibri,sans-serif\">This project implements an image \n      analysis pipeline for quantifying fluorescence coverage of &#223;-sheets on \n      circular titanium disks from tiled fluorescence microscopy images. Raw . \n      czi microscopy files are processed to extract tiles. A mask needs to be \n      created manually once the pipeline automatically requests it. This help \n      restricts the analysis to the disk surface. Fluorescent structures are \n      segmented within the disk using a consistent thresholding approach, \n      where the threshold were extracted from negative control images. The \n      final output provides coverage measurements across the experimental \n      conditions. The result table has two columns one for the file name and \n      one for the surface coverage value as a percentage. <o p=\"#DEFAULT\"></o></font></span>\n    </p>\n  </body>\n</html>\n",
    "authors" : [ {
      "title" : null,
      "first-name" : "Mounir",
      "last-name" : "Zerdani",
      "affiliations-list" : [ ],
      "affiliations-list-v2" : [ ],
      "website" : "https://www.leibniz-hki.de/en/asb-staff-details.html?member=1503",
      "contact" : null,
      "email" : "Mounir.Zerdani@leibniz-hki.de",
      "first-author" : false,
      "corresponding-author" : false,
      "orcid" : "0009-0003-5851-0951",
      "custom-text" : "<html><head></head><body></body></html>"
    } ],
    "acknowledgements" : [ ],
    "website" : "",
    "license" : "MIT",
