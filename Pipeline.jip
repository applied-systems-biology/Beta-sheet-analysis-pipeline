            }
          },
          "output" : {
            "stitched" : {
              "slot-data-type" : "imagej-imgplus",
              "slot-type" : "Output",
              "name" : "stitched",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : true,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:metadata-v1" : {
          "location/_/y" : 10,
          "location/_/x" : 1,
          "location/6de3573d-bca3-4fc2-a6bf-c1737a358a0c/x" : 1,
          "location/6de3573d-bca3-4fc2-a6bf-c1737a358a0c/y" : 23
        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "/*\nPurpose\n-------\nStitch previously exported tile images into a single mosaic using the\nImageJ plugin \"Grid/Collection stitching\". After stitching, the temporary\ntile folder is deleted.\n\nInputs (JiPipe)\n---------------\nInput : image stack (used only to access annotations)\n\nAnnotations used\n----------------\nParent : base directory containing the exported tiles\n#FILE  : name used to locate the tile folder (stitch_#FILE)\n\nOutputs (JiPipe)\n----------------\nstitched : fused stitched mosaic image\n*/\n\n\nselectWindow(\"Input\");\n\nparent = getJIPipeAnnotation(\"Parent\");\nfile   = getJIPipeAnnotation(\"#FILE\");\n\nINPUT = parent + \"/stitch_\" + file + \"/\";\nprint(getJIPipeAnnotation(\"Parent\") + \"/stitch_\" + getJIPipeAnnotation(\"#FILE\"));\n\n\n// Run stitching\nrun(\"Grid/Collection stitching\",\n\"type=[Grid: row-by-row] order=[Right & Down                ] grid_size_x=23 grid_size_y=23 tile_overlap=10 first_file_index_i=0 directory=\"+INPUT+\" file_names={iiii}.tiff output_textfile_name=TileConfiguration.txt fusion_method=[Linear Blending] regression_threshold=0.30 max/avg_displacement_threshold=2.50 absolute_displacement_threshold=3.50 computation_parameters=[Save memory (but be slower)] image_output=[Fuse and display]\");\n\nrun(\"Grays\");\n\n// -----------------------------\n// Delete temporary tile folder\n// -----------------------------\nfunction deleteFolder(path) {\n    list = getFileList(path);\n    for (i = 0; i < list.length; i++) {\n        if (File.isDirectory(path + list[i]))\n            deleteFolder(path + list[i]);\n        else\n            File.delete(path + list[i]);\n    }\n    File.delete(path);\n}\n\ndeleteFolder(INPUT);\n\n// Rename stitched image\nrename(\"stitched\");",
          "collapsed" : false
        },
        "import-delay" : 1000,
        "jipipe:node:bookmarked" : false,
        "jipipe:algorithm:pass-through" : false,
        "jipipe:node:name" : "Stitching II",
        "jipipe:algorithm:runtime-partition" : {
