              "is-optional" : false
            }
          }
        },
        "jipipe:metadata-v1" : {
          "location/_/y" : 66,
          "location/_/x" : 2,
          "location/6de3573d-bca3-4fc2-a6bf-c1737a358a0c/x" : 1,
          "location/6de3573d-bca3-4fc2-a6bf-c1737a358a0c/y" : 11
        },
        "jipipe:node-info-id" : "external-imagej-macro",
        "export-delay" : 250,
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "/*\nPurpose\n-------\nApply BaSiC flat-field correction to a stack image.\nThe macro estimates the flat-field shading profile and corrects the images.\n\nInputs (JiPipe)\n---------------\nInput : image stack\n\nOutputs (JiPipe)\n----------------\nOutput : shading-corrected image stack\n*/\n\n// Select input image\nselectWindow(\"Input\");\n\n// Set image properties (stack dimensions and calibration)\nrun(\"Properties...\", \"channels=1 slices=437 frames=1 pixel_width=1.0000 pixel_height=1.0000 voxel_depth=1.0000\");\n\n// Run BaSiC flat-field correction\nrun(\"BaSiC \", \"processing_stack=Input flat-field=None dark-field=None shading_estimation=[Estimate shading profiles] shading_model=[Estimate flat-field only (ignore dark-field)] setting_regularisationparametes=Manual temporal_drift=Ignore correction_options=[Compute shading and correct images] lambda_flat=0.1 lambda_dark=0.50\");\n\n// Close generated flat-field image\nselectImage(\"Flat-field:Input\");\nclose();\n\n// Rename corrected stack\nrename(\"Output\");",
          "collapsed" : false
        },
        "import-delay" : 1000,
        "jipipe:node:bookmarked" : false,
        "jipipe:algorithm:pass-through" : false,
        "jipipe:node:name" : "BASiC",
        "jipipe:algorithm:runtime-partition" : {
          "index" : 0
        },
        "jipipe:node:description" : "<html><head></head><body></body></html>",
        "external-code" : false,
        "jipipe:local-parallelization-num-threads" : {
          "content" : 1,
          "enabled" : false
        },
        "input-to-imagej-exporters/Input" : {
