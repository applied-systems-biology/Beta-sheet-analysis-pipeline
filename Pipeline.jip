      "d29b4a11-2540-47a1-9fbd-215318644b13" : {
        "jipipe:graph-compartment" : "6de3573d-bca3-4fc2-a6bf-c1737a358a0c",
        "jipipe:alias-id" : "stitching-i",
        "jipipe:slot-configuration" : {
          "input" : {
            "Input" : {
              "slot-data-type" : "imagej-imgplus",
              "slot-type" : "Input",
              "name" : "Input",
              "custom-name" : null,
              "description" : "",
