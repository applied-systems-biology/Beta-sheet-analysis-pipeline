        },
        "jipipe:metadata-v1" : {
          "location/_/y" : 6,
          "location/_/x" : 1,
          "location/6de3573d-bca3-4fc2-a6bf-c1737a358a0c/x" : 1,
          "location/6de3573d-bca3-4fc2-a6bf-c1737a358a0c/y" : 19
        },
        "jipipe:node-info-id" : "cpython-script-iterating",
        "annotation-merge-strategy" : "Merge",
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "\"\"\"\nPurpose\n-------\nSave a stack of images to disk as individual TIFF files inside a\nstitching folder. The folder is recreated each time to ensure a clean\nexport directory.\n\nInputs (JiPipe)\n---------------\nInput : image stack to export\n\nAnnotations used\n----------------\nParent : base directory where the export folder will be created\n#FILE  : filename used to construct the export folder name\n\nOutputs (JiPipe)\n----------------\nOutput : last image of the exported stack\n\"\"\"\n\nfrom jipipe.imagej import *\nfrom skimage.io import imsave\nfrom pathlib import Path\nimport shutil\nimport os\nimport stat\n\n\n# ---- helpers (cross-platform) ----\ndef rm_tree(path: Path):\n    \"\"\"Remove folder and contents (rm -rf), Windows/Ubuntu compatible.\"\"\"\n    if not path.exists():\n        return\n\n    def _on_rm_error(func, p, exc_info):\n        # Windows may mark files read-only -> make writable and retry\n        try:\n            os.chmod(p, stat.S_IWRITE)\n        except Exception:\n            pass\n        func(p)\n\n    shutil.rmtree(path, onerror=_on_rm_error)\n\n\n# ---- JIPipe input ----\nds = jipipe_inputs[\"Input\"]\nstack = load_image_file(data_slot=ds, row=0)\n\n# Build export folder path\nparent = Path(jipipe_annotations[\"Parent\"])\nfolder = parent / f\"stitch_{jipipe_annotations['#FILE']}\"\n\n# Recreate folder\nrm_tree(folder)\nfolder.mkdir(parents=True, exist_ok=True)\nprint(\"Folder recreated:\", folder.resolve())\n\n# Save stack as TIFF images\next = \".tiff\"\nfor i in range(stack.shape[0]):\n    fname = f\"{i:04d}{ext}\"\n    imsave(str(folder / fname), stack[i])\n\n# ---- Output ----\ndso = jipipe_outputs[\"Output\"]\nadd_image(stack[i], dso)",
          "collapsed" : false
        },
        "suppress-logs" : false,
        "jipipe:node:bookmarked" : false,
        "jipipe:algorithm:pass-through" : false,
        "jipipe:node:name" : "Stitching I",
        "jipipe:algorithm:runtime-partition" : {
          "index" : 0
        },
        "jipipe:node:description" : "<html><head></head><body></body></html>",
        "external-code" : false,
        "cleanup-afterwards" : true,
