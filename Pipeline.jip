      "427b797d-2687-4858-ba2d-fec9f8b4d32a" : {
        "jipipe:graph-compartment" : "6de3573d-bca3-4fc2-a6bf-c1737a358a0c",
        "jipipe:alias-id" : "pad-czi-tiles-1",
        "jipipe:slot-configuration" : {
          "input" : {
            "Input" : {
              "slot-data-type" : "imagej-imgplus",
              "slot-type" : "Input",
              "name" : "Input",
              "custom-name" : null,
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          },
          "output" : {
            "Output" : {
              "slot-data-type" : "imagej-imgplus",
              "slot-type" : "Output",
              "name" : "Output",
              "custom-name" : "529",
              "description" : "",
              "is-virtual" : false,
              "save-outputs" : true,
              "is-optional" : false
            }
          }
        },
        "jipipe:metadata-v1" : {
          "location/_/y" : 70,
          "location/_/x" : 2,
          "location/6de3573d-bca3-4fc2-a6bf-c1737a358a0c/x" : 1,
          "location/6de3573d-bca3-4fc2-a6bf-c1737a358a0c/y" : 15
        },
        "jipipe:node-info-id" : "cpython-script-iterating",
        "annotation-merge-strategy" : "Merge",
        "jipipe:algorithm:enabled" : true,
        "jipipe:node:ui-locked" : false,
        "code" : {
          "code" : "\"\"\"\nPurpose\n-------\nRearrange a tile stack into a padded grid layout for visualization.\n\nThe script maps tiles from the input stack to their correct spatial\npositions using a predefined row layout. It can handle both straight\n(row-major) and serpentine acquisition orders. The output stack contains\nblank frames where needed so each row has a fixed width.\n\nInputs (JiPipe)\n---------------\nInput : stack of tile images (N,H,W) or (N,H,W,C)\n\nOutputs (JiPipe)\n----------------\nOutput : reordered and padded tile stack arranged for grid display\n\"\"\"\n\nfrom jipipe.imagej import *\nimport numpy as np\n\n# ----------------------------\n# Layout config\n# ----------------------------\nMAX_PER_ROW = 23\n\nROW_TO_TILES = {\n    1:  list(range(0, 9)),\n    2:  list(range(9, 22)),\n    3:  list(range(22, 37)),\n    4:  list(range(37, 54)),\n    5:  list(range(54, 73)),\n    6:  list(range(73, 94)),\n    7:  list(range(94, 115)),\n    8:  list(range(115, 138)),\n    9:  list(range(138, 161)),\n    10: list(range(161, 184)),\n    11: list(range(184, 207)),\n    12: list(range(207, 230)),\n    13: list(range(230, 253)),\n    14: list(range(253, 276)),\n    15: list(range(276, 299)),\n    16: list(range(299, 322)),\n    17: list(range(322, 343)),\n    18: list(range(343, 364)),\n    19: list(range(364, 383)),\n    20: list(range(383, 400)),\n    21: list(range(400, 415)),\n    22: list(range(415, 428)),\n    23: list(range(428, 437)),\n}\n\n# ----------------------------\n# USER CHOICES\n# ----------------------------\n\n# Input stack ordering\n# \"row-major\"  = straight rows\n# \"serpentine\" = meander acquisition\nINPUT_ORDER = \"row-major\"\n\n# Display ordering based on metadata\nscan_mode = jipipe_annotations.get(\"ScanMode\", \"\").strip()\nSERPENTINE_DISPLAY = (scan_mode == \"Meander\")\n\n# Which rows flip in serpentine mode\nSERPENTINE_FLIP_ROWS = \"even\"\n\n# ----------------------------\n# Helpers\n# ----------------------------\n\ndef pad_row_to_fixed_width(row, width=MAX_PER_ROW):\n    pad = width - len(row)\n    left = pad // 2\n    right = pad - left\n    return [None]*left + row + [None]*right\n\ndef make_blank_like(example_frame: np.ndarray) -> np.ndarray:\n    if example_frame.ndim == 2:\n        H, W = example_frame.shape\n        return np.zeros((H, W), dtype=example_frame.dtype)\n    else:\n        H, W, C = example_frame.shape\n        return np.zeros((H, W, C), dtype=example_frame.dtype)\n\ndef should_flip_row(r: int, flip_rows: str) -> bool:\n    if flip_rows == \"even\":\n        return (r % 2 == 0)\n    elif flip_rows == \"odd\":\n        return (r % 2 == 1)\n    else:\n        raise ValueError(\"SERPENTINE_FLIP_ROWS must be 'even' or 'odd'.\")\n\ndef build_rows(serpentine: bool, flip_rows: str):\n    rows = []\n    for r in sorted(ROW_TO_TILES.keys()):\n        row = ROW_TO_TILES[r][:]\n        if serpentine and should_flip_row(r, flip_rows):\n            row.reverse()\n        rows.append(row)\n    return rows\n\n# ----------------------------\n# Input stack\n# ----------------------------\n\nds = jipipe_inputs[\"Input\"]\ntry:\n    stack_in = get_image(data_slot=ds, row=0)\nexcept NameError:\n    stack_in = load_image_file(data_slot=ds, row=0)\n\nstack_in = np.asarray(stack_in)\n\nif stack_in.ndim not in (3, 4):\n    raise RuntimeError(f\"Expected (N,H,W) or (N,H,W,C), got {stack_in.shape}\")\n\nN = stack_in.shape[0]\nexample = stack_in[0]\n\n# ----------------------------\n# Build INPUT tile sequence\n# ----------------------------\n\nif INPUT_ORDER == \"row-major\":\n    row_ids_input = build_rows(serpentine=False, flip_rows=\"even\")\nelif INPUT_ORDER == \"serpentine\":\n    row_ids_input = build_rows(serpentine=True, flip_rows=SERPENTINE_FLIP_ROWS)\nelse:\n    raise ValueError(\"INPUT_ORDER must be 'row-major' or 'serpentine'.\")\n\ntile_seq_input = [t for row in row_ids_input for t in row]\n\nif N != len(tile_seq_input):\n    raise RuntimeError(\n        f\"Input stack length ({N}) != number of real tiles ({len(tile_seq_input)}).\"\n    )\n\ntile_to_frame = {tile_idx: stack_in[i] for i, tile_idx in enumerate(tile_seq_input)}\n\n# ----------------------------\n# Build DISPLAY rows\n# ----------------------------\n\nrow_ids_display = build_rows(\n    serpentine=SERPENTINE_DISPLAY,\n    flip_rows=SERPENTINE_FLIP_ROWS\n)\n\npadded_rows = [pad_row_to_fixed_width(row, MAX_PER_ROW) for row in row_ids_display]\n\n# ----------------------------\n# Emit frames\n# ----------------------------\n\nblank = make_blank_like(example)\nframes_out = []\n\nfor row in padded_rows:\n    for t in row:\n        frames_out.append(blank if t is None else tile_to_frame[t])\n\nstack_out = np.stack(frames_out, axis=0)\n\n# ----------------------------\n# Output\n# ----------------------------\n\ndso = jipipe_outputs[\"Output\"]\nadd_image(stack_out, dso)",
          "collapsed" : false
        },
        "suppress-logs" : false,
