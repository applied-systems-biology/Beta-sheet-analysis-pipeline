      "1cf12866-c816-42b5-9acf-6034c6d13720" : {
        "jipipe:graph-compartment" : "6de3573d-bca3-4fc2-a6bf-c1737a358a0c",
        "jipipe:alias-id" : "stitching-ii",
        "jipipe:slot-configuration" : {
          "input" : {
            "Input" : {
              "slot-data-type" : "imagej-imgplus",
              "slot-type" : "Input",
              "name" : "Input",
              "custom-name" : null,
              "description" : "",
